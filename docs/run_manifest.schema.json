{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunManifest",
  "type": "object",
  "required": [
    "run_id",
    "source_file",
    "source_hash",
    "config_file",
    "config_hash",
    "started_at",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "source_hash": {
      "type": "string"
    },
    "config_file": {
      "type": "string"
    },
    "config_hash": {
      "type": "string"
    },
    "git_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "partial"
      ]
    },
    "steps_completed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
